# Copy to .env and fill in your values for the mock_server.py
# cp .env.template .env

# Mode: mock | anthropic | openai | proxy
OPENCLAW_MODE=mock

# API key (needed for anthropic/openai modes)
OPENCLAW_API_KEY=

# Proxy mode: forward to real OpenClaw agent WebSocket
OPENCLAW_AGENT_URL=

# Server bind address
OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=8000

# Optional JWT validation secret (blank = skip validation)
JWT_SECRET=
